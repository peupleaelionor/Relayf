# ─────────────────────────────────────────────────────────────────────────────
# RelayFlow Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
PORT=4000
LOG_LEVEL=debug

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL=postgresql://relayflow:password@localhost:5432/relayflow?sslmode=prefer
# DATABASE_DIRECT_URL is used for direct (non-pooled) connections during migrations.
# Required when using a connection pooler like PgBouncer or Neon's serverless driver.
# Set it to the same value as DATABASE_URL if not using a pooler.
DATABASE_DIRECT_URL=postgresql://relayflow:password@localhost:5432/relayflow?sslmode=prefer

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Format: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://default:password@localhost:6379
REDIS_TOKEN=your-upstash-redis-rest-token

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-use-openssl-rand-base64-64
JWT_REFRESH_SECRET=change-me-use-openssl-rand-base64-64-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe price IDs
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_GROWTH_MONTHLY=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_GROWTH_YEARLY=price_...
STRIPE_PRICE_SCALE_YEARLY=price_...

# ── Twilio (SMS/WhatsApp) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15005550006
TWILIO_WHATSAPP_NUMBER=+14155238886
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@relayflow.io
EMAIL_FROM_NAME=RelayFlow

# ── AWS S3 / Cloudflare R2 (file uploads) ────────────────────────────────────
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=relayflow-uploads
S3_PUBLIC_URL=https://cdn.relayflow.io

# ── OpenAI (AI features) ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Internal ──────────────────────────────────────────────────────────────────
INTERNAL_API_SECRET=change-me-internal-secret
WEBHOOK_SECRET=change-me-webhook-secret
ENCRYPTION_KEY=change-me-32-bytes-hex-encryption

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4000
