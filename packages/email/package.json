{
  "name": "@relayflow/email",
  "version": "0.1.0",
  "private": true,
  "description": "Email sending helpers for RelayFlow via Resend",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@relayflow/logger": "workspace:*",
    "resend": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.5"
  }
}
